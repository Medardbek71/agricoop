            <th style="padding-bottom: 16px; color: #888888; font-weight: 500; font-size: 13px; width: 15%; text-align: right;">Statut</th>
          </tr>
        </thead>
        <tbody>
          <!-- Ligne 1 : Stock Correct -->
          <tr style="border-bottom: 1px solid #fcfcfc;">
